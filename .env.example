# ============================================================
# Job Application Automation — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# ── AI Provider ─────────────────────────────────────────────
# Options: "gemini" | "grok"
AI_PROVIDER=gemini

# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# xAI Grok (OpenAI-compatible) — only needed if AI_PROVIDER=grok
GROK_API_KEY=your_grok_api_key_here
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-3

# ── SMTP / Email Delivery ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
# Gmail: create an App Password at https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your_app_password_here

# ── Sender Profile ───────────────────────────────────────────
SENDER_NAME=Your Full Name
SENDER_PHONE=+1 555 000 0000
SENDER_LINKEDIN=https://linkedin.com/in/yourprofile
SENDER_EMAIL=your_gmail@gmail.com

# ── Profile Summary (fed into AI prompt) ────────────────────
# Paste a concise bio of yourself: role, top skills, years of experience,
# 2-3 key achievements. Keep it under 300 words.
PROFILE_SUMMARY="Software engineer with 5 years of experience in Python, cloud infrastructure, and data pipelines. Led migration of legacy systems to AWS, reducing costs by 40%. Passionate about clean code and developer tooling."

# ── File Paths ───────────────────────────────────────────────
JOBS_CSV_PATH=jobs.csv
CV_PATH=cv.pdf
SENT_LOG_PATH=sent_log.csv
LOG_DIR=logs

# ── Email Template ───────────────────────────────────────────
# {position} and {company} are available as placeholders
EMAIL_SUBJECT_TEMPLATE=Application for {position} at {company}

# ── Rate Limiting ────────────────────────────────────────────
# Seconds between each email send (chosen randomly in this range)
MIN_DELAY_SECONDS=20
MAX_DELAY_SECONDS=60

# ── Safety ───────────────────────────────────────────────────
# Set to "true" to compose & log emails WITHOUT actually sending them.
# Change to "false" only when you're ready for live sends.
DRY_RUN=true

# Max retries for transient SMTP/API failures
MAX_RETRIES=2

# ── Database ─────────────────────────────────────────────────
# Path to the SQLite tracker database (auto-created on first run)
DB_PATH=applications.db

# ── Telegram Bot ─────────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy the token here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# 2. Get your chat ID: message @userinfobot or start your bot → check logs
# Comma-separated. Leave empty to allow ALL (not recommended).
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# ── Job Discovery ─────────────────────────────────────────────
# Keywords to search for automatically
JOB_KEYWORDS=Software Engineer Python
# Location to search in
JOB_LOCATION=Nairobi, Kenya
# Include remote/hybrid jobs (true/false)
JOB_REMOTE=true
# Experience level preference (junior / mid / senior)
JOB_EXPERIENCE=mid
# Minimum salary filter (0 = no minimum)
JOB_MIN_SALARY=0
# Sources to search (comma-separated): indeed, google, linkedin
JOB_DISCOVERY_SOURCES=indeed,google
# SerpAPI key for Google Jobs (optional — https://serpapi.com, free tier: 100/month)
SERPAPI_KEY=your_serpapi_key_here
